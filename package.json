{
  "name": "gherkin-step-navigator",
  "displayName": "Gherkin Step Navigator",
  "description": "Navigate from Gherkin feature steps to code.",
  "icon": "icon.png",
  "version": "1.0.8",
  "publisher": "DannyBriskin",
  "author": {
    "name": "Danny Briskin"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.97.0"
  },
  "main": "./out/main.js",
  "categories": [
    "Programming Languages",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "gherkin",
    "cucumber",
    "specflow",
    "behave",
    "bdd",
    "automation"
  ],
  "activationEvents": [
    "onLanguage:gherkin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danny-briskin/gherkin-step-navigator.git"
  },
  "bugs": {
    "url": "https://github.com/danny-briskin/gherkin-step-navigator/issues",
    "email": "sql.coach.kiev@gmail.com"
  },
  "homepage": "https://github.com/danny-briskin/gherkin-step-navigator",
  "contributes": {
    "languages": [
      {
        "id": "gherkin",
        "extensions": [
          ".feature"
        ],
        "aliases": [
          "Gherkin",
          "feature"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gherkin",
        "scopeName": "source.gherkin",
        "path": "./syntaxes/feature.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Gherkin Step Navigator",
      "properties": {
        "gherkinStepNavigator.stepFilePattern": {
          "type": "array",
          "default": [
            "**/*Steps.cs",
            "**/*.java",
            "**/*.py"
          ],
          "description": "Glob patterns to find step definition files.",
          "items": {
            "type": "string"
          }
        },
        "gherkinStepNavigator.diagnostics.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show diagnostics in .feature files for unresolved and ambiguous step definitions."
        },
        "gherkinStepNavigator.indent.scenario": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "maximum": 16,
          "description": "Spaces before Scenario, Background, and Examples blocks."
        },
        "gherkinStepNavigator.indent.step": {
          "type": "integer",
          "default": 4,
          "minimum": 0,
          "maximum": 16,
          "description": "Spaces before Given/When/Then/And/But steps."
        },
        "gherkinStepNavigator.indent.table": {
          "type": "integer",
          "default": 6,
          "minimum": 0,
          "maximum": 16,
          "description": "Spaces before table rows (| col | col |)."
        },
        "gherkinStepNavigator.indent.tableComment": {
          "type": "integer",
          "default": 6,
          "minimum": 0,
          "maximum": 16,
          "description": "Spaces before table comments (# | ... |)."
        },
        "gherkinStepNavigator.indent.docstring": {
          "type": "integer",
          "default": 6,
          "minimum": 0,
          "maximum": 16,
          "description": "Spaces before Documentation lines."
        },
        "gherkinStepNavigator.indent.tag": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "maximum": 16,
          "description": "Spaces before tags (@tagName). Tags attached to a Feature/Scenario inherit its indentation."
        },
        "gherkinStepNavigator.indent.comment": {
          "type": "integer",
          "default": 4,
          "minimum": 0,
          "maximum": 16,
          "description": "Spaces before isolated comments (# ...). Comments preceding a block inherit its indentation."
        }
      }
    }
  },
  "scripts": {
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
    "compile": "npm run bundle && tsc -p ./ && npm run copy-fixtures",
    "copy-fixtures": "cpx \"src/test/fixtures/**/*\" out/",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.1",
    "@types/vscode": "^1.97.0",
    "cpx2": "^4.0.0",
    "esbuild": "^0.27.3",
    "glob": "^13.0.6",
    "serialize-javascript": ">=7.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "diff": ">=8.0.3",
    "glob": "^10.0.0",
    "mocha": "^11.7.5",
    "serialize-javascript": ">=7.0.3"
  }
}
